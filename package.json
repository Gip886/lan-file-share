{
  "name": "lan-file-share",
  "version": "1.0.0",
  "private": true,
  "description": "局域网文件共享系统",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @lan-file-share/server dev\" \"pnpm --filter @lan-file-share/web dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "build:web": "pnpm --filter @lan-file-share/web build",
    "build:server": "pnpm --filter @lan-file-share/server build",
    "pack": "node scripts/pack.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}